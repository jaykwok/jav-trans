# JAVTrans 本地持久配置模板。
# 复制为 .env 后填写真实值；不要把真实 .env 提交到 Git：
#   Copy-Item .env.example .env
#
# 当前 Web 工作流里，视频路径、输出目录、字幕模式、worker、
# 是否保留临时文件等任务级参数都来自 Web 表单，并通过 JobContext
# 传入后端。ASR/VAD 键可作为本地默认偏好或高级调参项保留在 .env。
#
# .env 只保留跨任务持久配置：API 密钥、翻译服务、模型镜像、
# 默认翻译偏好、ASR/VAD 默认偏好和高级调参项。
# Web 设置页修改翻译服务、模型镜像、演员名和术语表时，也会写回 .env。

# --- ASR ---
ASR_BACKEND=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame  # 默认/推荐 ASR 后端；可选 jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame
ASR_VAD_BACKEND=fusionvad_ja       # 当前唯一主线 VAD
# 演员名、人名或领域词提示；Web 设置页会持久化到 .env。
ASR_CONTEXT=
ASR_LONG_CHUNK_PROFILE=on           # on: 默认开启 chunk packing
ASR_CHUNK_PACKING_ENABLED=1         # FusionVAD-JA speech island chunk packing
ASR_CHUNK_PACK_FRAME_HOP_S=0.033366700033366704  # 无视频 fps 时按 29.97fps 兜底
ASR_CHUNK_PACK_WINDOW_FRAMES=899    # forced-aligner feature window
ASR_CHUNK_PACK_RESERVE_FRAMES=45    # feature window 内安全预留
ASR_CHUNK_PACK_TARGET_PADDING_FRAMES=60  # VAD speech 两端动态 padding 目标
ASR_CHUNK_PACK_GAP_MERGE_FRAMES=45  # 小于此帧数的 gap 可合并进同 packed chunk
ASR_CHUNK_PACK_MAX_CORE_FRAMES=0    # packed core 软上限；0=关闭，边界优化优先走 R18
ASR_PRE_ASR_ISLAND_SPLIT_ENABLED=0  # R15/R16: 高风险长 chunk 在 ASR 前按 speech island 切分
ASR_PRE_ASR_ISLAND_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_ISLAND_SPLIT_MIN_GAP_FRAMES=18
ASR_PRE_ASR_ISLAND_SPLIT_MIN_ISLAND_FRAMES=3
ASR_PRE_ASR_ISLAND_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_VALLEY_SPLIT_ENABLED=0  # R16: 长连续 positive island 按低分 valley 试切
ASR_PRE_ASR_VALLEY_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_VALLEY_SPLIT_TARGET_CORE_FRAMES=270
ASR_PRE_ASR_VALLEY_SPLIT_MIN_VALLEY_FRAMES=6
ASR_PRE_ASR_VALLEY_SPLIT_MIN_CHILD_FRAMES=45
ASR_PRE_ASR_VALLEY_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_VALLEY_SPLIT_THRESHOLD=0.20
ASR_PRE_ASR_CUT_SPLIT_ENABLED=0     # R17: 长连续 positive island 按 endpoint cut 分数试切
ASR_PRE_ASR_CUT_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_CUT_SPLIT_TARGET_CORE_FRAMES=270
ASR_PRE_ASR_CUT_SPLIT_MIN_CUT_FRAMES=3
ASR_PRE_ASR_CUT_SPLIT_MIN_CHILD_FRAMES=45
ASR_PRE_ASR_CUT_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_CUT_SPLIT_THRESHOLD=0.94
ASR_PRE_ASR_RISK_SPLIT_ENABLED=0    # R18: fallback-risk-aware boundary packing, 默认关闭
ASR_PRE_ASR_RISK_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_RISK_SPLIT_TARGET_CORE_FRAMES=270
ASR_PRE_ASR_RISK_SPLIT_SAFE_CORE_FRAMES=360
ASR_PRE_ASR_RISK_SPLIT_MIN_GAP_FRAMES=6
ASR_PRE_ASR_RISK_SPLIT_MIN_CHILD_FRAMES=45
ASR_PRE_ASR_RISK_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_RISK_SPLIT_THRESHOLD=1.0
ASR_PRE_ASR_RISK_SPLIT_CONTINUOUS_THRESHOLD=2.0  # 无明确 gap 的连续长 island 需更高风险才允许 cut/valley 切
ASR_PRE_ASR_RISK_SPLIT_VALLEY_THRESHOLD=0.20
ASR_PRE_ASR_RISK_SPLIT_CUT_THRESHOLD=0.94
FUSIONVAD_JA_EXPORT_FRAME_SCORES=0  # R16 诊断/valley split 才开启，默认不写大数组进 cache
FUSIONVAD_JA_CHECKPOINT=src/vad/fusionvad_ja/checkpoints/fusionvad_ja_v1_19b_splitcut_touch4096_endpoint_refiner.pt
ASR_MODEL_ID=                       # 留空时使用 ASR_BACKEND 对应的 Hugging Face repo id
ASR_MODEL_PATH=                     # 本地模型路径显式覆盖；留空使用 models/<namespace>-<repo> 或自动下载
FUSIONVAD_JA_MODEL_PATH=models/jaykwok-Qwen3-ASR-0.6B-JA-Anime-Galgame
FUSIONVAD_JA_NO_DOWNLOAD=0         # 0: 缺本地 0.6B full SFT 特征模型时从 Hugging Face 下载
FUSIONVAD_JA_THRESHOLD=0.200        # v1.19b split-cut speech threshold
FUSIONVAD_JA_CUT_THRESHOLD=0.500    # v1.19b split-cut cut_drop/cut_point threshold
FUSIONVAD_JA_APPLY_CUT_TO_SPEECH=1  # 1: cut_drop/cut_point 命中时从 speech mask 中切开

# --- VAD/chunk cache ---
VAD_CHUNK_CACHE_ENABLED=1           # 独立缓存 VAD/chunk 边界；不绑定 ASR prompt/token 参数
VAD_CHUNK_CACHE_DIR=./temp/vad-cache

# --- ASR generation / adaptive precision ---
ASR_INITIAL_PROMPT_MAX_CHARS=240    # 滑动上下文 prompt 字符上限
ASR_INITIAL_PROMPT_MAX_TOKENS=180   # Qwen ASR context prompt token 上限
ASR_MIN_EFFECTIVE_NEW_TOKENS=64     # prompt 挤占 decoder 窗口时保留的最小生成空间
ASR_QC_ENABLED=1                    # 1: ASR 文本进入翻译前启用质量诊断
ASR_QC_DROP_UNCERTAIN=0             # 1: 允许 QC 清空高风险 ASR 文本；默认只记录诊断
ASR_QC_ADAPTIVE_BASE_LOGPROB=-0.7
ASR_QC_ADAPTIVE_MIN_LOGPROB=-0.95
ASR_QC_ADAPTIVE_MAX_LOGPROB=-0.55
ASR_QC_ADAPTIVE_VIDEO_MAD_MULTIPLIER=1.8
ASR_QC_ADAPTIVE_VIDEO_MAX_LOGPROB=-0.70
ASR_QC_ADAPTIVE_HARD_NOSPEECH_THRESHOLD=0.5
ASR_QC_ADAPTIVE_HARD_MAX_CHARS_PER_SEC=14.0
ASR_QC_ADAPTIVE_HARD_COMPRESSION_THRESHOLD=2.0
ASR_QC_ADAPTIVE_HARD_REPEAT_RATIO=0.45

# --- 字幕时长 ---
# Netflix Timed Text 指南使用 7s 作为行业上限；本项目默认 5.5s 软目标、6.5s 硬上限。
# SRT 写出会用 ffprobe 探测视频 fps 并保留 2 帧间隔；探测失败按 29.97fps 兜底。
MAX_SUBTITLE_DURATION=6.5
SUBTITLE_SOFT_MAX_S=5.5
SUBTITLE_SOFT_SPLIT_ENABLED=1
ASR_MERGE_HARD_MAX_DURATION=9.0     # ASR 片段合并硬上限；超过后不再继续合并

F0_GENDER_POST_ALIGNMENT=0          # legacy/ablation: F0/gender split 后置到词级对齐之后
F0_GENDER_NONE_TOLERANCE=3          # 连续 N 个 None 词才确认 None group
F0_GENDER_CARRYOVER_ENABLED=1       # None 段两侧同性别时继承 segment gender
F0_GENDER_CARRYOVER_MAX_GAP_S=15.0  # carry-over 左右锚点最大间隔秒数
F0_GENDER_CARRYOVER_MAX_SEGMENT_S=12.0  # 可继承的 None 段自身最大秒数
SUBTITLE_MIN_DURATION_GENDER_TURN=0.4  # gender turn 场景下的最短字幕时长
ALIGN_LONG_CHUNK_BATCH_SIZE=1       # 长 chunk forced alignment 批大小（长 chunk 下保持 1 避免 OOM）

# --- 质量报告 ---
# Web 勾选质量报告时默认写入 video/<视频名>/；如需覆盖目录再填写此项。
QUALITY_REPORT_DIR=
QC_MAX_ASR_GENERATION_ERRORS=0      # ASR 生成异常数超过该值时报告 warning
QC_MAX_ASR_GENERATION_OVERFLOWS=0   # decoder overflow 超过该值时报告 warning
QC_MAX_ALIGN_FALLBACK=0.20          # forced alignment fallback 比例超过该值时报告 warning

# --- 翻译服务 ---
# 翻译服务 API Key。必须填写真实值。
API_KEY=your_key_here

# OpenAI-compatible API 地址，例如 DeepSeek 或其他兼容服务。
OPENAI_COMPATIBILITY_BASE_URL=https://api.deepseek.com

# 翻译模型名。
LLM_MODEL_NAME=deepseek-v4-pro

# 翻译 API 格式。chat 使用 /chat/completions；responses 使用 /responses。
# 默认 chat，只有 OpenAI Responses API 或兼容服务需要改为 responses。
LLM_API_FORMAT=chat

# 支持 reasoning effort 的模型可设置；不支持的服务可保持默认。
# 可选值由 Web 后端限制为 medium / xhigh。
LLM_REASONING_EFFORT=xhigh

# 目标语言。
TARGET_LANG=简体中文

# --- 模型下载 / 网络 ---
# HuggingFace 镜像地址。留空表示使用官方 huggingface.co。
# 必须包含 http:// 或 https://，例如：https://hf-mirror.com
HF_ENDPOINT=
# HF_ENDPOINT=https://hf-mirror.com

# --- 翻译偏好 ---
# 术语表格式：原文-译文, 原文-译文
# TRANSLATION_GLOSSARY=ちんぽ-肉棒, チンポ-肉棒
