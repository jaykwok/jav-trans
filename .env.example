# JAVTrans local persistent configuration template.
# Copy this file to .env and fill real private values there. Do not commit .env.
#
# Web task options such as video path, output directory, subtitle mode,
# translation workers, and whether to keep temporary files are submitted from
# the Web UI per job. This file is for cross-job defaults: API credentials,
# model download/cache preferences, and advanced ASR/VAD tuning.

# --- Runtime paths / Web ---
# Model and Hugging Face cache root. Relative paths are resolved from project root.
HF_HOME=./models
# torch.hub runtime cache; not a model directory.
TORCH_HOME=./temp/torch
# Per-job temporary files.
JOB_TEMP_DIR=./temp/jobs

# Launcher/Web ports.
JAVTRANS_PORT=17321
JAVTRANS_EVENTS_PORT=17322

# Optional CUDA allocator mitigation for fragmentation/OOM during Qwen/FusionVAD runs.
# Uncomment only when running with CUDA.
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- Qwen ASR / Forced alignment ---
# Current mainline ASR backends. The 0.6B SFT model is the default/recommended backend.
ASR_BACKEND=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame
# Optional: switch to the larger backend.
# ASR_BACKEND=jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame

# Leave empty to derive the Hugging Face repo from ASR_BACKEND.
ASR_MODEL_ID=
# Leave empty to use models/<namespace>-<repo>, downloading when missing.
ASR_MODEL_PATH=

ALIGNER_MODEL_ID=Qwen/Qwen3-ForcedAligner-0.6B
# Leave empty to use models/Qwen-Qwen3-ForcedAligner-0.6B.
ALIGNER_MODEL_PATH=
ALIGNMENT_TIMESTAMP_MODE=forced

# CUDA-friendly defaults. Use float16 if your GPU does not support bfloat16.
ASR_DTYPE=bfloat16
ASR_ATTENTION=sdpa
ASR_BATCH_SIZE=1
ALIGNER_BATCH_SIZE=4
ALIGN_LONG_CHUNK_BATCH_SIZE=1

ASR_LANGUAGE=Japanese
ASR_FORCE_LANGUAGE=1
# Actor names, character names, or domain terms used as ASR context.
ASR_CONTEXT=
# Optional extra context applied only near the beginning of a video.
ASR_HEAD_CONTEXT=
ASR_HEAD_CONTEXT_MAX_START_S=16

ASR_MAX_NEW_TOKENS=128
TRANSCRIPTION_MAX_NEW_TOKENS=128
ASR_REPETITION_PENALTY=1.05
ASR_SUBPROCESS_READY_TIMEOUT_S=600
# subprocess isolates GPU model lifetime and is the normal Web workflow.
ASR_WORKER_MODE=subprocess

# Sliding prompt budget for Qwen ASR context.
ASR_INITIAL_PROMPT_MAX_CHARS=240
ASR_INITIAL_PROMPT_MAX_TOKENS=180
ASR_MIN_EFFECTIVE_NEW_TOKENS=64

# Native timestamp guardrails. Mainline still uses forced alignment by default.
ASR_NATIVE_MIN_SPAN_MS=80
ASR_NATIVE_MAX_ZERO_RATIO=0.55
ASR_NATIVE_MAX_REPEAT_RATIO=0.65
ASR_NATIVE_MAX_CHARS_PER_ITEM=12.0

# --- FusionVAD-JA ---
ASR_VAD_BACKEND=fusionvad_ja
FUSIONVAD_JA_MODEL_PATH=models/jaykwok-Qwen3-ASR-0.6B-JA-Anime-Galgame
FUSIONVAD_JA_NO_DOWNLOAD=0
FUSIONVAD_JA_PTM=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame

# Small VAD heads are committed with the repository.
FUSIONVAD_JA_CHECKPOINT=src/vad/fusionvad_ja/checkpoints/fusionvad_ja_v1_19b_splitcut_touch4096_endpoint_refiner.pt
FUSIONVAD_JA_IMITATION_CHECKPOINT=src/vad/fusionvad_ja/checkpoints/fusionvad_ja_v1_21_dropgap_imitation_head.pt

# Current operating point.
FUSIONVAD_JA_THRESHOLD=0.200
FUSIONVAD_JA_PAD_S=0.2
FUSIONVAD_JA_FRAME_HOP_S=0.02
FUSIONVAD_JA_CUT_THRESHOLD=0.500
FUSIONVAD_JA_APPLY_CUT_TO_SPEECH=1

# FusionVAD-JA runtime/device settings.
FUSIONVAD_JA_DEVICE=auto
FUSIONVAD_JA_DTYPE=bfloat16
FUSIONVAD_JA_ATTENTION=sdpa
FUSIONVAD_JA_WINDOW_S=30.0
FUSIONVAD_JA_OVERLAP_S=1.0
FUSIONVAD_JA_MIN_SEGMENT_S=0.05
FUSIONVAD_JA_MERGE_GAP_S=0.0
FUSIONVAD_JA_MAX_GROUP_S=6.0
FUSIONVAD_JA_CHUNK_THRESHOLD_S=1.0

# Diagnostics only; keep off for normal runs because frame arrays are large.
FUSIONVAD_JA_EXPORT_FRAME_SCORES=0
FUSIONVAD_JA_EXPORT_DROP_GAP_SCORES=0

# --- VAD/chunk cache and packing ---
VAD_CHUNK_CACHE_ENABLED=1
VAD_CHUNK_CACHE_DIR=./temp/vad-cache

# Frame-based chunk packing. FPS-aware jobs override frame hop from video fps.
ASR_LONG_CHUNK_PROFILE=on
ASR_CHUNK_PACKING_ENABLED=1
ASR_CHUNK_PACK_FRAME_HOP_S=0.033366700033366704
ASR_CHUNK_PACK_WINDOW_FRAMES=899
ASR_CHUNK_PACK_RESERVE_FRAMES=45
ASR_CHUNK_PACK_TARGET_PADDING_FRAMES=60
ASR_CHUNK_PACK_GAP_MERGE_FRAMES=45
# 0 disables the old packed-core soft cap. Boundary work should use the opt-in splitters below.
ASR_CHUNK_PACK_MAX_CORE_FRAMES=0

# Short low-energy chunk dropping is conservative and disabled by default.
ASR_CHUNK_DROP_ENABLED=0
ASR_CHUNK_DROP_MIN_DURATION_S=0.20
ASR_CHUNK_DROP_RMS_DBFS=-40.0

# Legacy/fallback segmenter values used only outside FusionVAD-JA packed paths.
VAD_MIN_OFF=0.1
VAD_PAD=0.15
SEGMENT_MIN_SILENCE=0.35
SEGMENT_MIN_CHUNK=1.2
SEGMENT_MAX_CHUNK=12.0
SEGMENT_TARGET_CHUNK=12.0
SEGMENT_MIN_SPEECH=0.25
SEGMENT_PAD=0.15

# --- Experimental pre-ASR boundary packing (default off) ---
# These switches are for reproducing R15-R18 experiments. Turning them on changes the
# VAD chunk cache key and can increase ASR chunk count.
ASR_PRE_ASR_ISLAND_SPLIT_ENABLED=0
ASR_PRE_ASR_ISLAND_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_ISLAND_SPLIT_MIN_GAP_FRAMES=18
ASR_PRE_ASR_ISLAND_SPLIT_MIN_ISLAND_FRAMES=3
ASR_PRE_ASR_ISLAND_SPLIT_MAX_CHILDREN=8

ASR_PRE_ASR_VALLEY_SPLIT_ENABLED=0
ASR_PRE_ASR_VALLEY_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_VALLEY_SPLIT_TARGET_CORE_FRAMES=270
ASR_PRE_ASR_VALLEY_SPLIT_MIN_VALLEY_FRAMES=6
ASR_PRE_ASR_VALLEY_SPLIT_MIN_CHILD_FRAMES=45
ASR_PRE_ASR_VALLEY_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_VALLEY_SPLIT_THRESHOLD=0.20

ASR_PRE_ASR_CUT_SPLIT_ENABLED=0
ASR_PRE_ASR_CUT_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_CUT_SPLIT_TARGET_CORE_FRAMES=270
ASR_PRE_ASR_CUT_SPLIT_MIN_CUT_FRAMES=3
ASR_PRE_ASR_CUT_SPLIT_MIN_CHILD_FRAMES=45
ASR_PRE_ASR_CUT_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_CUT_SPLIT_THRESHOLD=0.94

ASR_PRE_ASR_DROP_GAP_SPLIT_ENABLED=0
ASR_PRE_ASR_DROP_GAP_SPLIT_MIN_PARENT_FRAMES=400
ASR_PRE_ASR_DROP_GAP_SPLIT_MIN_GAP_FRAMES=3
ASR_PRE_ASR_DROP_GAP_SPLIT_MIN_GAP_S=0.60
ASR_PRE_ASR_DROP_GAP_SPLIT_MIN_CHILD_FRAMES=25
ASR_PRE_ASR_DROP_GAP_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_DROP_GAP_SPLIT_THRESHOLD=0.80

ASR_PRE_ASR_RISK_SPLIT_ENABLED=0
ASR_PRE_ASR_RISK_SPLIT_MIN_CORE_FRAMES=420
ASR_PRE_ASR_RISK_SPLIT_TARGET_CORE_FRAMES=270
ASR_PRE_ASR_RISK_SPLIT_SAFE_CORE_FRAMES=360
ASR_PRE_ASR_RISK_SPLIT_MIN_GAP_FRAMES=6
ASR_PRE_ASR_RISK_SPLIT_MIN_CHILD_FRAMES=45
ASR_PRE_ASR_RISK_SPLIT_MAX_CHILDREN=8
ASR_PRE_ASR_RISK_SPLIT_THRESHOLD=1.0
ASR_PRE_ASR_RISK_SPLIT_CONTINUOUS_THRESHOLD=2.0
ASR_PRE_ASR_RISK_SPLIT_VALLEY_THRESHOLD=0.20
ASR_PRE_ASR_RISK_SPLIT_CUT_THRESHOLD=0.94

# --- Alignment fallback/refine ---
ALIGNMENT_HYBRID_FORCE_MAX_CHUNK=24.0
ALIGNMENT_HYBRID_FORCE_MIN_TEXT_LEN=20
ALIGNMENT_COARSE_REFINE_CHUNK=18.0
ALIGNMENT_MAX_REFINE_DEPTH=2
ALIGNMENT_STEP_DOWN_CHUNK=6.0
ALIGNMENT_MIN_SPAN_MS=120
ALIGNMENT_MAX_ZERO_RATIO=0.55
ALIGNMENT_MAX_REPEAT_RATIO=0.65
ALIGNMENT_MAX_COVERAGE_RATIO=0.05
ALIGNMENT_MAX_CPS=50.0
ALIGNMENT_RETRY_SKIP_MAX_TEXT_LEN=10

# Sentinel fallback island split is off by default; useful for diagnostics.
ALIGNMENT_SENTINEL_ISLAND_SPLIT=0
ALIGNMENT_SENTINEL_ISLAND_MIN_S=0.25
ALIGNMENT_SENTINEL_ISLAND_PAD_FRAMES=6
ALIGNMENT_SENTINEL_ISLAND_MERGE_GAP_FRAMES=6
ALIGNMENT_SENTINEL_ISLAND_MAX_SPLITS=8

# --- ASR QC / post-processing ---
ASR_CONTEXT_LEAK_SIMILARITY=0.88
ASR_FRAGMENT_MERGE_MAX_GAP=1.0
ASR_FRAGMENT_MERGE_MAX_CHARS=72
ASR_FRAGMENT_MERGE_MAX_DURATION=12.5
ASR_MERGE_HARD_MAX_DURATION=9.0

ASR_QC_ENABLED=1
ASR_QC_DROP_UNCERTAIN=0
ASR_QC_ADAPTIVE_BASE_LOGPROB=-0.7
ASR_QC_ADAPTIVE_MIN_LOGPROB=-0.95
ASR_QC_ADAPTIVE_MAX_LOGPROB=-0.55
ASR_QC_ADAPTIVE_VIDEO_MAD_MULTIPLIER=1.8
ASR_QC_ADAPTIVE_VIDEO_MAX_LOGPROB=-0.70
ASR_QC_ADAPTIVE_HARD_NOSPEECH_THRESHOLD=0.5
ASR_QC_ADAPTIVE_HARD_MAX_CHARS_PER_SEC=14.0
ASR_QC_ADAPTIVE_HARD_COMPRESSION_THRESHOLD=2.0
ASR_QC_ADAPTIVE_HARD_REPEAT_RATIO=0.45

# Nonlexical repeats can be true target-domain text; default behavior marks/reviews
# rather than dropping uncertain ASR output.
ASR_QC_REPETITION_THRESHOLD=10
ASR_QC_REPEAT_MIN_RUN=4
ASR_QC_REPEAT_MIN_RATIO=0.40
ASR_QC_HALLUCINATION_MIN_CHARS=50
ASR_QC_DENSITY_MIN_CHARS=30
ASR_QC_LOW_INFO_DURATION=6.0
ASR_QC_LOW_INFO_MAX_CHARS=5
ASR_QC_EMPTY_DURATION=1.0
ASR_QC_LONG_LOW_VALUE_DURATION=6.0
ASR_QC_NONLEXICAL_REPEAT_MAX_DURATION=12.0
ASR_QC_NONLEXICAL_REPEAT_MAX_UNIT_LEN=4
ASR_QC_NONLEXICAL_REPEAT_MAX_CPS=8.0
ASR_QC_REPETITION_TRUNCATE_KEEP_RUNS=3

# --- Subtitle timing ---
# Netflix-style timing: keep start close to speech, allow end polish/compression,
# and preserve a 2-frame gap when fps is known.
MAX_SUBTITLE_DURATION=6.5
SUBTITLE_SOFT_MAX_S=5.5
SUBTITLE_SOFT_SPLIT_ENABLED=1
MIN_SUBTITLE_DURATION=0.6
SUBTITLE_READING_CPS=7.0
SUBTITLE_READING_BASE=0.35
SUBTITLE_DURATION_RATIO_CAP=1.65
SUBTITLE_DURATION_GRACE=0.9
SUBTITLE_BILINGUAL_SECONDARY_WEIGHT=0.4

# --- Quality report ---
QUALITY_REPORT_ENABLED=0
QUALITY_REPORT_DIR=
KEEP_QUALITY_REPORT=0
QC_HARD_FAIL=0
QC_MAX_EMPTY_ZH=0.02
QC_MAX_REPETITION=0.05
QC_MAX_KANA_ONLY=0.30
QC_MAX_SHORT_SEG=0.15
QC_MAX_PER_MIN=8
QC_MIN_GLOSSARY_HIT=0.80
QC_MAX_ALIGN_FALLBACK=0.20
QC_MAX_ASR_GENERATION_ERRORS=0
QC_MAX_ASR_GENERATION_OVERFLOWS=0

# --- Optional speaker/F0 cue helpers ---
# Not the current main VAD strategy. Leave defaults unless reproducing old
# multi-cue/F0 experiments or speaker-sidecar probes.
EXPERIMENTAL_SPEAKER_DIARIZATION=0
SPEAKER_MODEL=speechbrain/spkrec-ecapa-voxceleb
SPEAKER_MIN_DURATION=0.5
SPEAKER_CLUSTER_THRESHOLD=0.5
SPEAKER_MAX_CLUSTERS=5
SUBTITLE_SHOW_SPEAKER=0

MULTI_CUE_SPLIT_ENABLED=1
F0_GENDER_POST_ALIGNMENT=0
F0_GENDER_NONE_TOLERANCE=3
F0_GENDER_CARRYOVER_ENABLED=1
F0_GENDER_CARRYOVER_MAX_GAP_S=15.0
F0_GENDER_CARRYOVER_MAX_SEGMENT_S=12.0
SUBTITLE_MIN_DURATION_GENDER_TURN=0.4
KEEP_WORD_TIMESTAMPS=0
F0_THRESHOLD_HZ=160
F0_NAN_RATIO_THRESHOLD=0.6
F0_WORD_WINDOW_MS=300
F0_RMS_GATE_DB=-45.0
F0_WORD_MIN_SPAN_MS=500
F0_FILTER_NONE_SEGMENTS=0

# --- Audio ---
AUDIO_DYNAUDNORM=1
AUDIO_USE_LOUDNORM=0

# --- Translation service ---
# Fill with your real translation API key in .env.
API_KEY=your_key_here

# OpenAI-compatible API base URL, for example DeepSeek or another compatible provider.
OPENAI_COMPATIBILITY_BASE_URL=https://api.deepseek.com

# Translation model name.
LLM_MODEL_NAME=deepseek-v4-pro

# chat uses /chat/completions; responses uses /responses.
LLM_API_FORMAT=chat

# Valid values enforced by the Web backend: medium / xhigh.
LLM_REASONING_EFFORT=xhigh

TARGET_LANG=简体中文

# Glossary format: source-target, source-target
TRANSLATION_GLOSSARY=ちんぽ-肉棒, チンポ-肉棒, おちんちん-肉棒, チンポコ-肉棒

# --- Model download / network ---
# Empty means official huggingface.co. For mainland China acceleration:
# HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=

# Optional StageEvent sink: empty disables events; file:, tcp:, and memory are supported.
STAGE_EVENT_SINK=

# Test-only crash injection for translation resume tests. Leave empty.
_TEST_CRASH_TRANSLATION_BATCH=
