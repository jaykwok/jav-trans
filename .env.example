# JAVTrans local configuration template.
# Copy to .env and fill private values there. Do not commit .env.
#
# Omitted options use src/core/config.py defaults. Keep this file short:
# only cross-job settings that users commonly change should live here.

# --- Runtime paths / Web ---
HF_HOME=./models
TORCH_HOME=./tmp/cache/torch
JOB_TEMP_DIR=./tmp/jobs
ASR_CHUNK_ROOT=./tmp/chunks
JAVTRANS_PORT=17321
JAVTRANS_EVENTS_PORT=17322

# Empty means official huggingface.co. For mainland China acceleration:
# HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=

# Optional CUDA allocator mitigation for fragmentation/OOM.
# Uncomment only when running with CUDA.
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- Qwen ASR ---
# Default/recommended backend is 1.7B. This model-family selector also drives
# the repo-id registry for trained Boundary/Scorer checkpoints.
ASR_BACKEND=jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame-hf
# Low-config fallback:
# ASR_BACKEND=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame-hf

# Leave empty to resolve/download from ASR_BACKEND.
ASR_MODEL_ID=
ASR_MODEL_PATH=

# CUDA-friendly defaults. Use float16 if your GPU does not support bfloat16.
ASR_DTYPE=bfloat16
ASR_ATTENTION=sdpa
ASR_WORKER_MODE=subprocess

# 6GB-class 1.7B defaults. For an 8GB card, a tested local profile can raise
# ASR 1.7B to 64 and ASR 0.6B to 128.
# ASR_BATCH_SIZE=auto resolves by ASR_BACKEND using this repo-id table.
ASR_BATCH_SIZE=auto
ASR_BATCH_SIZE_BY_REPO=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame-hf=64,jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame-hf=32

ASR_LANGUAGE=Japanese
ASR_FORCE_LANGUAGE=1

# Max generated tokens per ASR chunk. Raise only if output is truncated mid-sentence.
ASR_MAX_NEW_TOKENS=128
# Hard timeout (seconds) for transcribing one chunk. Raise for slow GPUs / very long chunks.
TRANSCRIPTION_TIMEOUT_S=180
# --- SpeechBoundary-JA / Boundary Refiner ---
ASR_BOUNDARY_BACKEND=speech_boundary_ja

# SpeechBoundary-JA uses the same Qwen repo id as frozen PTM features.
# SpeechBoundary-JA PTM and local model path follow ASR_BACKEND automatically.
SPEECH_BOUNDARY_JA_DEVICE=auto
SPEECH_BOUNDARY_JA_DTYPE=bfloat16
# Learned scorer follows the selected repo id and must be schema v7.
# Experimental override example:
# SPEECH_BOUNDARY_JA_SCORER_CHECKPOINT_BY_REPO=jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame-hf=src/boundary/ja/checkpoints/custom.pt
SPEECH_BOUNDARY_JA_SCORER_DEVICE=auto
# Advanced adaptive split decoder overrides. Keep commented unless running a controlled scorer experiment.
# These values still affect speech mask extraction, local peak ranking, and boundary cache signatures.
# They are not duration hard-drop or dense-cut resolver controls.
# SPEECH_BOUNDARY_JA_THRESHOLD=0.5
# SPEECH_BOUNDARY_JA_FRAME_DILATION_S=0.2
# SPEECH_BOUNDARY_JA_SPLIT_SCORE_QUANTILE=0.50
# SPEECH_BOUNDARY_JA_SPLIT_PROMINENCE_QUANTILE=0.50
# SPEECH_BOUNDARY_JA_SPLIT_SMOOTH_S=0.08
# SPEECH_BOUNDARY_JA_SPLIT_NMS_S=0.20
# SPEECH_BOUNDARY_JA_SPLIT_SNAP_S=0.10
# SPEECH_BOUNDARY_JA_MIN_SPLIT_SEGMENT_S=0.08

BOUNDARY_CACHE_ENABLED=1
BOUNDARY_CACHE_DIR=./tmp/cache/boundary


# --- Optional Pre-ASR CueQC v10 keep/drop router ---
# Disabled by default. Uncomment only after assigning an audited repo-matched v10 checkpoint.
# PRE_ASR_CUEQC_ENABLED=1
# PRE_ASR_CUEQC_MODEL_PATH_BY_REPO=jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame-hf=./path/to/cueqc_pre_asr_mamba_v10_binary.pt
# PRE_ASR_CUEQC_DEVICE=auto
# PRE_ASR_CUEQC_DROP_THRESHOLD=0.95


# --- Translation service ---
# Leave API_KEY empty if you only run Japanese ASR/subtitle generation.
API_KEY=
OPENAI_COMPATIBILITY_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-flash
LLM_API_FORMAT=chat
LLM_REASONING_EFFORT=xhigh
TARGET_LANG=简体中文

# Glossary format: source-target, source-target
TRANSLATION_GLOSSARY=ちんぽ-肉棒, チンポ-肉棒, おちんちん-肉棒, チンポコ-肉棒

# --- Optional reports ---
QUALITY_REPORT_ENABLED=0
KEEP_QUALITY_REPORT=0
