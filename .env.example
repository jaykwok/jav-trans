# JAVTrans local persistent configuration template.
# Copy this file to .env and fill real private values there. Do not commit .env.
#
# Web task options such as video path, output directory, subtitle mode,
# translation workers, and whether to keep temporary files are submitted from
# the Web UI per job. This file is for cross-job defaults: API credentials,
# model download/cache preferences, and advanced ASR / speech-boundary tuning.

# --- Runtime paths / Web ---
# Model and Hugging Face cache root. Relative paths are resolved from project root.
HF_HOME=./models
# torch.hub runtime cache; not a model directory.
TORCH_HOME=./temp/torch
# Per-job temporary files.
JOB_TEMP_DIR=./temp/jobs

# Launcher/Web ports.
JAVTRANS_PORT=17321
JAVTRANS_EVENTS_PORT=17322

# Optional CUDA allocator mitigation for fragmentation/OOM during Qwen / SpeechBoundary-JA runs.
# Uncomment only when running with CUDA.
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- Qwen ASR / Forced alignment ---
# Current mainline ASR backends. The 0.6B SFT model is the default/recommended backend.
ASR_BACKEND=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame
# Optional: switch to the larger backend.
# ASR_BACKEND=jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame

# Leave empty to derive the Hugging Face repo from ASR_BACKEND.
ASR_MODEL_ID=
# Leave empty to use models/<namespace>-<repo>, downloading when missing.
ASR_MODEL_PATH=

ALIGNER_MODEL_ID=Qwen/Qwen3-ForcedAligner-0.6B
# Leave empty to use models/Qwen-Qwen3-ForcedAligner-0.6B.
ALIGNER_MODEL_PATH=
ALIGNMENT_TIMESTAMP_MODE=forced

# CUDA-friendly defaults. Use float16 if your GPU does not support bfloat16.
ASR_DTYPE=bfloat16
ASR_ATTENTION=sdpa
ASR_BATCH_SIZE=1
ALIGNER_BATCH_SIZE=4
ALIGN_LONG_CHUNK_BATCH_SIZE=1

ASR_LANGUAGE=Japanese
ASR_FORCE_LANGUAGE=1
# Actor names, character names, or domain terms used as ASR context.
ASR_CONTEXT=
# Optional extra context applied only near the beginning of a video.
ASR_HEAD_CONTEXT=
ASR_HEAD_CONTEXT_MAX_START_S=16

ASR_MAX_NEW_TOKENS=128
TRANSCRIPTION_MAX_NEW_TOKENS=128
ASR_REPETITION_PENALTY=1.05
ASR_SUBPROCESS_READY_TIMEOUT_S=600
# subprocess isolates GPU model lifetime and is the normal Web workflow.
ASR_WORKER_MODE=subprocess

# Sliding prompt budget for Qwen ASR context.
ASR_INITIAL_PROMPT_MAX_CHARS=240
ASR_INITIAL_PROMPT_MAX_TOKENS=180
ASR_MIN_EFFECTIVE_NEW_TOKENS=64

# Native timestamp guardrails. Mainline still uses forced alignment by default.
ASR_NATIVE_MIN_SPAN_MS=80
ASR_NATIVE_MAX_ZERO_RATIO=0.55
ASR_NATIVE_MAX_REPEAT_RATIO=0.65
ASR_NATIVE_MAX_CHARS_PER_ITEM=12.0

# --- SpeechBoundary-JA bootstrap scorer ---
# JA target-domain boundary scorer. Generic candidate/refiner/planner code lives
# under src/boundary/, and the JA bootstrap scorer lives under src/boundary/ja/.
ASR_BOUNDARY_BACKEND=speech_boundary_ja
SPEECH_BOUNDARY_JA_MODEL_PATH=models/jaykwok-Qwen3-ASR-0.6B-JA-Anime-Galgame
SPEECH_BOUNDARY_JA_NO_DOWNLOAD=0
SPEECH_BOUNDARY_JA_PTM=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame

# Bootstrap operating point. Learned split/merge/refine decisions live in Boundary Refiner.
SPEECH_BOUNDARY_JA_THRESHOLD=0.200
SPEECH_BOUNDARY_JA_PAD_S=0.2
SPEECH_BOUNDARY_JA_FRAME_HOP_S=0.02
SPEECH_BOUNDARY_JA_CUT_THRESHOLD=0.500
SPEECH_BOUNDARY_JA_APPLY_CUT_TO_SPEECH=1

# SpeechBoundary-JA runtime/device settings.
SPEECH_BOUNDARY_JA_DEVICE=auto
SPEECH_BOUNDARY_JA_DTYPE=bfloat16
SPEECH_BOUNDARY_JA_ATTENTION=sdpa
SPEECH_BOUNDARY_JA_WINDOW_S=30.0
SPEECH_BOUNDARY_JA_OVERLAP_S=1.0
SPEECH_BOUNDARY_JA_MIN_SEGMENT_S=0.05
SPEECH_BOUNDARY_JA_MERGE_GAP_S=0.0
SPEECH_BOUNDARY_JA_MAX_GROUP_S=6.0
SPEECH_BOUNDARY_JA_CHUNK_THRESHOLD_S=1.0

# Diagnostics only; keep off for normal runs because frame arrays are large.
SPEECH_BOUNDARY_JA_EXPORT_FRAME_SCORES=0

# ASR chunk export/post-processing.
ASR_CHUNK_MIN_DURATION_S=0.25
ASR_CONTEXT_RESET_GAP_S=0.5

# --- Boundary Refiner / semantic pre-ASR packing ---
# Empty model path uses the deterministic bootstrap refiner. Learned refiner checkpoints
# use the boundary_refiner_v1 schema. The only supported backbone code is the actual
# implementation path, transformers.Mamba2Model.
# runtime_adapter=frame_sequence_v1 checkpoints are fail-fast: feature names/hash must
# match src/boundary/sequence_features.py and SpeechBoundary-JA exported frame windows.
# Planner chunk limits are ASR/acoustic context seconds. The feature frame hop is
# the boundary frame-score grid fallback, not the source video's subtitle FPS.
BOUNDARY_CACHE_ENABLED=1
BOUNDARY_CACHE_DIR=./temp/boundary-cache
BOUNDARY_FEATURE_FRAME_HOP_S=0.02
BOUNDARY_REFINER_ENABLED=1
BOUNDARY_REFINER_MODEL_PATH=src/boundary/checkpoints/boundary_refiner.pt
BOUNDARY_REFINER_BACKBONE=transformers.Mamba2Model
BOUNDARY_REFINER_THRESHOLD=0.5
BOUNDARY_FRAME_SEQUENCE_LEFT_CONTEXT_S=0.60
BOUNDARY_FRAME_SEQUENCE_RIGHT_CONTEXT_S=0.60
BOUNDARY_FRAME_SEQUENCE_MAX_PTM_DIMS=64
BOUNDARY_FRAME_SEQUENCE_INCLUDE_MFCC=1
BOUNDARY_PLANNER_MAX_CHUNK_S=30.0
BOUNDARY_PLANNER_TARGET_CHUNK_S=9.0
BOUNDARY_PLANNER_MIN_CHUNK_S=0.4
BOUNDARY_PLANNER_START_WEIGHT=1.5
BOUNDARY_PLANNER_TARGET_PADDING_S=2.0
BOUNDARY_PLANNER_MAX_SPLITS_PER_SEGMENT=16
BOUNDARY_PLANNER_SEQUENCE_BATCH_SIZE=256
BOUNDARY_DROP_LOW_ENERGY_ENABLED=0
BOUNDARY_DROP_LOW_ENERGY_MIN_DURATION_S=0.20
BOUNDARY_DROP_LOW_ENERGY_RMS_DBFS=-40.0

# --- Alignment fallback/refine ---
ALIGNMENT_HYBRID_FORCE_MAX_CHUNK=24.0
ALIGNMENT_HYBRID_FORCE_MIN_TEXT_LEN=20
ALIGNMENT_COARSE_REFINE_CHUNK=18.0
ALIGNMENT_MAX_REFINE_DEPTH=2
ALIGNMENT_STEP_DOWN_CHUNK=6.0
ALIGNMENT_MIN_SPAN_MS=120
ALIGNMENT_MAX_ZERO_RATIO=0.55
ALIGNMENT_MAX_REPEAT_RATIO=0.65
ALIGNMENT_MAX_COVERAGE_RATIO=0.05
ALIGNMENT_MAX_CPS=50.0
ALIGNMENT_RETRY_SKIP_MAX_TEXT_LEN=10

# Sentinel fallback island split is off by default; useful for diagnostics.
ALIGNMENT_SENTINEL_ISLAND_SPLIT=0
ALIGNMENT_SENTINEL_ISLAND_MIN_S=0.25
ALIGNMENT_SENTINEL_ISLAND_PAD_FRAMES=6
ALIGNMENT_SENTINEL_ISLAND_MERGE_GAP_FRAMES=6
ALIGNMENT_SENTINEL_ISLAND_MAX_SPLITS=8

# --- ASR QC / post-processing ---
ASR_CONTEXT_LEAK_SIMILARITY=0.88
ASR_FRAGMENT_MERGE_MAX_GAP=1.0
ASR_FRAGMENT_MERGE_MAX_CHARS=72
ASR_FRAGMENT_MERGE_MAX_DURATION=12.5
ASR_MERGE_HARD_MAX_DURATION=9.0

ASR_QC_ENABLED=1
ASR_QC_DROP_UNCERTAIN=0
ASR_QC_ADAPTIVE_BASE_LOGPROB=-0.7
ASR_QC_ADAPTIVE_MIN_LOGPROB=-0.95
ASR_QC_ADAPTIVE_MAX_LOGPROB=-0.55
ASR_QC_ADAPTIVE_VIDEO_MAD_MULTIPLIER=1.8
ASR_QC_ADAPTIVE_VIDEO_MAX_LOGPROB=-0.70
ASR_QC_ADAPTIVE_HARD_NOSPEECH_THRESHOLD=0.5
ASR_QC_ADAPTIVE_HARD_MAX_CHARS_PER_SEC=14.0
ASR_QC_ADAPTIVE_HARD_COMPRESSION_THRESHOLD=2.0
ASR_QC_ADAPTIVE_HARD_REPEAT_RATIO=0.45

# Nonlexical repeats can be true target-domain text; default behavior marks/reviews
# rather than dropping uncertain ASR output.
ASR_QC_REPETITION_THRESHOLD=10
ASR_QC_REPEAT_MIN_RUN=4
ASR_QC_REPEAT_MIN_RATIO=0.40
ASR_QC_HALLUCINATION_MIN_CHARS=50
ASR_QC_DENSITY_MIN_CHARS=30
ASR_QC_LOW_INFO_DURATION=6.0
ASR_QC_LOW_INFO_MAX_CHARS=5
ASR_QC_EMPTY_DURATION=1.0
ASR_QC_LONG_LOW_VALUE_DURATION=6.0
ASR_QC_NONLEXICAL_REPEAT_MAX_DURATION=12.0
ASR_QC_NONLEXICAL_REPEAT_MAX_UNIT_LEN=4
ASR_QC_NONLEXICAL_REPEAT_MAX_CPS=8.0
ASR_QC_REPETITION_TRUNCATE_KEEP_RUNS=3

# --- Subtitle timing ---
# Netflix-style timing uses the source video's real FPS: keep start close to
# speech, allow end polish/compression, and preserve a 2-frame gap.
MAX_SUBTITLE_DURATION=6.5
SUBTITLE_SOFT_MAX_S=5.5
SUBTITLE_SOFT_SPLIT_ENABLED=1
MIN_SUBTITLE_DURATION=0.6
SUBTITLE_READING_CPS=7.0
SUBTITLE_READING_BASE=0.35
SUBTITLE_DURATION_RATIO_CAP=1.65
SUBTITLE_DURATION_GRACE=0.9
SUBTITLE_BILINGUAL_SECONDARY_WEIGHT=0.4

# --- Quality report ---
QUALITY_REPORT_ENABLED=0
QUALITY_REPORT_DIR=
KEEP_QUALITY_REPORT=0
QC_HARD_FAIL=0
QC_MAX_EMPTY_ZH=0.02
QC_MAX_REPETITION=0.05
QC_MAX_KANA_ONLY=0.30
QC_MAX_SHORT_SEG=0.15
QC_MAX_PER_MIN=8
QC_MIN_GLOSSARY_HIT=0.80
QC_MAX_ALIGN_FALLBACK=0.20
QC_MAX_ASR_GENERATION_ERRORS=0
QC_MAX_ASR_GENERATION_OVERFLOWS=0

# --- Audio ---
AUDIO_DYNAUDNORM=1
AUDIO_USE_LOUDNORM=0

# --- Translation service ---
# Fill with your real translation API key in .env.
API_KEY=your_key_here

# OpenAI-compatible API base URL, for example DeepSeek or another compatible provider.
OPENAI_COMPATIBILITY_BASE_URL=https://api.deepseek.com

# Translation model name.
LLM_MODEL_NAME=deepseek-v4-pro

# chat uses /chat/completions; responses uses /responses.
LLM_API_FORMAT=chat

# Valid values enforced by the Web backend: medium / xhigh.
LLM_REASONING_EFFORT=xhigh

TARGET_LANG=简体中文

# Glossary format: source-target, source-target
TRANSLATION_GLOSSARY=ちんぽ-肉棒, チンポ-肉棒, おちんちん-肉棒, チンポコ-肉棒

# --- Model download / network ---
# Empty means official huggingface.co. For mainland China acceleration:
# HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=

# Optional StageEvent sink: empty disables events; file:, tcp:, and memory are supported.
STAGE_EVENT_SINK=

# Test-only crash injection for translation resume tests. Leave empty.
_TEST_CRASH_TRANSLATION_BATCH=
