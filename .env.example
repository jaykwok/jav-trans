# JAVTrans 本地持久配置模板。
# 复制为 .env 后填写真实值；不要把真实 .env 提交到 Git：
#   Copy-Item .env.example .env
#
# 当前 Web 工作流里，视频路径、输出目录、ASR 后端、字幕模式、
# batch/worker、是否保留临时文件等任务级参数都来自 Web 表单，
# 并通过 JobContext 传入后端；不建议再写到 .env。
#
# .env 只保留跨任务持久配置：API 密钥、翻译服务、模型镜像、
# 默认翻译偏好。Web 设置页修改这些字段时，也会写回 .env。

# --- 翻译服务 ---
# 翻译服务 API Key。必须填写真实值。
API_KEY=your_key_here

# OpenAI-compatible API 地址，例如 DeepSeek 或其他兼容服务。
OPENAI_COMPATIBILITY_BASE_URL=https://api.deepseek.com

# 翻译模型名。
LLM_MODEL_NAME=deepseek-v4-pro

# 支持 reasoning effort 的模型可设置；不支持的服务可保持默认。
# 可选值由 Web 后端限制为 low / medium / max。
LLM_REASONING_EFFORT=max

# 目标语言。
TARGET_LANG=简体中文

# --- 模型下载 / 网络 ---
# HuggingFace 镜像地址。留空表示使用官方 huggingface.co。
# 必须包含 http:// 或 https://，例如：https://hf-mirror.com
# HF_ENDPOINT=https://hf-mirror.com

# --- 翻译偏好 ---
# 术语表格式：原文→译文, 原文→译文
# TRANSLATION_GLOSSARY=ちんぽ→肉棒, チンポ→肉棒
