# JAVTrans local configuration template.
# Copy to .env and fill private values there. Do not commit .env.
#
# Omitted options use src/core/config.py defaults. Keep this file short:
# only cross-job settings that users commonly change should live here.

# --- Runtime paths / Web ---
HF_HOME=./models
TORCH_HOME=./tmp/cache/torch
JOB_TEMP_DIR=./tmp/jobs
ASR_CHUNK_ROOT=./tmp/chunks
JAVTRANS_PORT=17321
JAVTRANS_EVENTS_PORT=17322

# Empty means official huggingface.co. For mainland China acceleration:
# HF_ENDPOINT=https://hf-mirror.com
HF_ENDPOINT=

# Optional CUDA allocator mitigation for fragmentation/OOM.
# Uncomment only when running with CUDA.
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- Qwen ASR ---
# Default/recommended backend is the 1.7B full SFT model.
ASR_BACKEND=jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame
# Low-config fallback:
# ASR_BACKEND=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame

# Leave empty to resolve/download from ASR_BACKEND.
ASR_MODEL_ID=
ASR_MODEL_PATH=

# CUDA-friendly defaults. Use float16 if your GPU does not support bfloat16.
ASR_DTYPE=bfloat16
ASR_ATTENTION=sdpa
ASR_WORKER_MODE=subprocess

# 6GB-class 1.7B defaults. For an 8GB card, a tested local profile can raise
# ASR 1.7B to 64 and ASR 0.6B to 128.
# ASR_BATCH_SIZE=auto resolves by ASR_BACKEND using this repo-id table.
ASR_BATCH_SIZE=auto
ASR_BATCH_SIZE_BY_REPO=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame=64,jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame=32

ASR_LANGUAGE=Japanese
ASR_FORCE_LANGUAGE=1
# Actor names, series names, or domain terms used as ASR context.
ASR_CONTEXT=
ASR_HEAD_CONTEXT=
ASR_HEAD_CONTEXT_MAX_START_S=16

# --- SpeechBoundary-JA / Boundary Refiner ---
ASR_BOUNDARY_BACKEND=speech_boundary_ja

# SpeechBoundary-JA uses the same Qwen repo id as frozen PTM features.
# Keep this aligned with ASR_BACKEND when switching between 1.7B and 0.6B.
SPEECH_BOUNDARY_JA_PTM=jaykwok/Qwen3-ASR-1.7B-JA-Anime-Galgame
SPEECH_BOUNDARY_JA_MODEL_PATH=models/jaykwok-Qwen3-ASR-1.7B-JA-Anime-Galgame
SPEECH_BOUNDARY_JA_DEVICE=auto
SPEECH_BOUNDARY_JA_DTYPE=bfloat16
# Optional learned Mamba2 scorer. Empty means bootstrap frame scores.
# If set, entries must be repo_id=checkpoint and must include SPEECH_BOUNDARY_JA_PTM.
# Low-config 0.6B opt-in candidate:
# SPEECH_BOUNDARY_JA_SCORER_CHECKPOINT_BY_REPO=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame=src/boundary/ja/checkpoints/speech_boundary_ja_feature_scorer.jaykwok-Qwen3-ASR-0.6B-JA-Anime-Galgame.pt
# Add a 1.7B entry only after retraining the scorer on 1.7B features.
SPEECH_BOUNDARY_JA_SCORER_CHECKPOINT_BY_REPO=
SPEECH_BOUNDARY_JA_SCORER_DEVICE=auto
# Frame-score mask dilation before raw segment extraction. This is not ASR padding/context.
SPEECH_BOUNDARY_JA_FRAME_DILATION_S=0.2

BOUNDARY_CACHE_ENABLED=1
BOUNDARY_CACHE_DIR=./tmp/cache/boundary
# Required repo-id keyed checkpoint map. Entries are repo_id=path.
# Add a 1.7B entry after retraining the Boundary Refiner on 1.7B features.
BOUNDARY_REFINER_MODEL_PATH_BY_REPO=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame=src/boundary/checkpoints/boundary_refiner.jaykwok-Qwen3-ASR-0.6B-JA-Anime-Galgame.pt

# Derived from Galgame/anime duration stats with target_domain_speedup=1.5:
# speech core stays short and is the ASR chunk window.
# Recompute with tools/boundary/recommend_timing_params.py when source mix changes.
BOUNDARY_PLANNER_TARGET_CHUNK_S=3.0
BOUNDARY_PLANNER_MAX_CORE_CHUNK_S=5.0
BOUNDARY_PLANNER_MIN_CHUNK_S=0.4

# --- CueQC Mamba v3-Fusion (display keep/drop binary filter) ---
CUEQC_SHADOW_ENABLED=1
# v3-Fusion: ASR encoder features + token trace + decoder stats + structured.
CUEQC_DECISION_VERSION=cueqc_display_binary_v1
CUEQC_MODEL_VERSION=cueqc_mamba_v3_fusion
# Required repo-id keyed checkpoint map. Entries are repo_id=path.
# Add a 1.7B entry after retraining CueQC on 1.7B ASR internals.
CUEQC_MODEL_PATH_BY_REPO=jaykwok/Qwen3-ASR-0.6B-JA-Anime-Galgame=src/asr/checkpoints/cueqc_mamba_v3_fusion.jaykwok-Qwen3-ASR-0.6B-JA-Anime-Galgame.pt
# drop only when p_drop >= threshold (conservative); else keep.
CUEQC_DROP_THRESHOLD=0.85
# 1 = actually remove model-confirmed drops before subtitle timing; 0 = shadow only.
CUEQC_DROP_APPLY_ENABLED=1
CUEQC_DEVICE=auto
CUEQC_EXPORT_CANDIDATES_PATH=
CUEQC_EXPORT_CANDIDATES_APPEND=1
CUEQC_SHADOW_EMBED_CANDIDATES=0

# --- Subtitle timing ---
# Keep subtitle settings compact. The writer applies Netflix-style
# 2-frame gap and timing polish; it no longer merges adjacent cues.
MAX_SUBTITLE_DURATION=6.5
SUBTITLE_SOFT_MAX_S=5.5

# --- Translation service ---
# Leave API_KEY empty if you only run Japanese ASR/subtitle generation.
API_KEY=
OPENAI_COMPATIBILITY_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-flash
LLM_API_FORMAT=chat
LLM_REASONING_EFFORT=xhigh
TARGET_LANG=简体中文

# Glossary format: source-target, source-target
TRANSLATION_GLOSSARY=ちんぽ-肉棒, チンポ-肉棒, おちんちん-肉棒, チンポコ-肉棒

# --- Optional reports ---
QUALITY_REPORT_ENABLED=0
KEEP_QUALITY_REPORT=0
