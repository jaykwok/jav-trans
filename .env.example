# JAVTrans 本地持久配置模板。
# 复制为 .env 后填写真实值；不要把真实 .env 提交到 Git：
#   Copy-Item .env.example .env
#
# 当前 Web 工作流里，视频路径、输出目录、字幕模式、worker、
# 是否保留临时文件等任务级参数都来自 Web 表单，并通过 JobContext
# 传入后端。ASR/VAD 键可作为本地默认偏好或高级调参项保留在 .env。
#
# .env 只保留跨任务持久配置：API 密钥、翻译服务、模型镜像、
# 默认翻译偏好、ASR/VAD 默认偏好和高级调参项。
# Web 设置页修改翻译服务、模型镜像、演员名和术语表时，也会写回 .env。

# --- ASR ---
ASR_BACKEND=whisper-ja-anime-v0.3   # 默认/推荐 ASR 后端
ASR_VAD_BACKEND=fusion_lite        # 默认/推荐；可选 whisperseg-adaptive
# 演员名、人名或领域词提示；Web 设置页会持久化到 .env。
ASR_CONTEXT=
ASR_VAD_ADAPTIVE=1                  # WhisperSeg 根据整段 speech_ratio 自适应调一次阈值
ASR_LONG_CHUNK_PROFILE=on           # on: 默认开启 chunk packing + F0 后置
ASR_CHUNK_PACKING_ENABLED=1         # VAD chunk packing (WhisperX 风格)
ASR_CHUNK_PACK_MAX_S=28.0           # 单 packed chunk 最大秒数
ASR_CHUNK_PACK_GAP_MERGE_S=1.5      # VAD 段间隔 < 此值时并入同 chunk
ASR_CHUNK_PACK_PADDING_S=2.0        # chunk 两端各留 padding
WHISPERSEG_THRESHOLD=0.35           # WhisperSeg 默认阈值，偏召回
WHISPERSEG_MIN_SPEECH_MS=100
WHISPERSEG_MIN_SILENCE_MS=100
WHISPERSEG_PAD_MS=300
WHISPERSEG_MAX_SPEECH_S=5.0
WHISPERSEG_MAX_GROUP_S=6.0
WHISPERSEG_CHUNK_THRESHOLD_S=1.0
WHISPERSEG_NEG_THRESHOLD_OFFSET=0.15 # whisperseg-adaptive 负阈值偏移；会进入 VAD cache signature
WHISPERSEG_FORCE_CPU=0              # 1: 强制 WhisperSeg 走 CPU，显存紧张时可临时启用

# --- Timestamp fallback VAD（只补时间轴，不改写 ASR 文本） ---
TEN_VAD_BACKEND=1                   # 1: alignment fallback 优先尝试 TEN VAD；失败再走 Silero
# Linux/WSL 使用 TEN VAD 需要系统库 libc++1 和 libc++abi1，详见 README 源码安装说明。
TIMESTAMP_VAD_ONSET=0.5             # TEN/Silero fallback VAD 触发阈值
TIMESTAMP_VAD_MIN_SPEECH=0.25       # Silero fallback 最短语音秒数
VAD_MIN_OFF=0.1                     # fallback VAD 合并相邻语音的最小静音间隔
VAD_PAD=0.15                        # fallback VAD 给语音区间增加的 padding 秒数

# --- Fusion-lite 内部 VAD 组件 ---
# fusion_lite 使用 WhisperSeg 抓候选，并把 Silero 作为内部 speech prior；不建议单独把 Silero 当主 VAD。
ASR_VAD_PRIMARY=whisperseg
ASR_VAD_GATE=silero
SILERO_VAD_THRESHOLD=0.35
SILERO_VAD_MIN_SPEECH_MS=80
SILERO_VAD_MIN_SILENCE_MS=80
SILERO_VAD_PAD_MS=300
SILERO_VAD_MAX_SPEECH_S=30.0
SILERO_VAD_MAX_GROUP_S=6.0
SILERO_VAD_CHUNK_THRESHOLD_S=1.0
SILERO_VAD_ONNX=1

# --- Fusion-lite VAD（实验，可选） ---
# 默认启用 fusion_lite；可用 ASR_VAD_BACKEND=whisperseg-adaptive 对比。
# 它融合 WhisperSeg 分数、Silero 重叠、RMS、spectral flux 和时长分数，不引入 pyannote 或训练流程。
FUSION_VAD_PRIMARY_WEIGHT=0.45
FUSION_VAD_GATE_WEIGHT=0.25
FUSION_VAD_RMS_WEIGHT=0.15
FUSION_VAD_SPECTRAL_FLUX_WEIGHT=0.10
FUSION_VAD_DURATION_WEIGHT=0.05
FUSION_VAD_MIN_SCORE=0.45
FUSION_VAD_MIN_GATE_OVERLAP_RATIO=0.05
FUSION_VAD_GATE_PAD_S=0.30
FUSION_VAD_DEFAULT_PRIMARY_SCORE=0.50
FUSION_VAD_RMS_FLOOR_DBFS=-50.0
FUSION_VAD_RMS_FULL_DBFS=-24.0
FUSION_VAD_SPECTRAL_FLUX_FLOOR=0.0002
FUSION_VAD_SPECTRAL_FLUX_FULL=0.0060
FUSION_VAD_DURATION_MIN_S=0.20
FUSION_VAD_DURATION_FULL_S=0.50
FUSION_VAD_DURATION_MAX_S=12.0

# --- VAD/chunk cache ---
VAD_CHUNK_CACHE_ENABLED=1           # 独立缓存 VAD/chunk 边界；不绑定 ASR prompt/token 参数
VAD_CHUNK_CACHE_DIR=./temp/vad-cache

# --- ASR generation / adaptive precision ---
WHISPER_MAX_NEW_TOKENS=444          # Whisper 系列配置上限，运行时会按 decoder 窗口动态裁剪
ASR_INITIAL_PROMPT_MAX_CHARS=240    # 滑动上下文 prompt 字符上限
ASR_INITIAL_PROMPT_MAX_TOKENS=180   # Whisper initial_prompt token 上限
ASR_MIN_EFFECTIVE_NEW_TOKENS=64     # Whisper prompt 挤占 448 decoder 窗口时保留的最小生成空间
ASR_QC_ENABLED=1                    # 1: ASR 文本进入翻译前启用质量诊断
ASR_QC_DROP_UNCERTAIN=0             # 1: 允许 QC 清空高风险 ASR 文本；默认只记录诊断
ASR_QC_ADAPTIVE_BASE_LOGPROB=-0.7
ASR_QC_ADAPTIVE_MIN_LOGPROB=-0.95
ASR_QC_ADAPTIVE_MAX_LOGPROB=-0.55
ASR_QC_ADAPTIVE_VIDEO_MAD_MULTIPLIER=1.8
ASR_QC_ADAPTIVE_VIDEO_MAX_LOGPROB=-0.70
ASR_QC_ADAPTIVE_HARD_NOSPEECH_THRESHOLD=0.5
ASR_QC_ADAPTIVE_HARD_MAX_CHARS_PER_SEC=14.0
ASR_QC_ADAPTIVE_HARD_COMPRESSION_THRESHOLD=2.0
ASR_QC_ADAPTIVE_HARD_REPEAT_RATIO=0.45

# --- 字幕时长 ---
# Netflix Timed Text 指南使用 7s 作为行业上限；本项目默认 5.5s 软目标、6.5s 硬上限。
# SRT 写出会用 ffprobe 探测视频 fps 并保留 2 帧间隔；探测失败按 29.97fps 兜底。
MAX_SUBTITLE_DURATION=6.5
SUBTITLE_SOFT_MAX_S=5.5
SUBTITLE_SOFT_SPLIT_ENABLED=1
ASR_MERGE_HARD_MAX_DURATION=9.0     # ASR 片段合并硬上限；超过后不再继续合并

F0_GENDER_POST_ALIGNMENT=1          # F0/gender split 后置到词级对齐之后
F0_GENDER_NONE_TOLERANCE=3          # 连续 N 个 None 词才确认 None group
F0_GENDER_CARRYOVER_ENABLED=1       # None 段两侧同性别时继承 segment gender
F0_GENDER_CARRYOVER_MAX_GAP_S=15.0  # carry-over 左右锚点最大间隔秒数
F0_GENDER_CARRYOVER_MAX_SEGMENT_S=12.0  # 可继承的 None 段自身最大秒数
SUBTITLE_MIN_DURATION_GENDER_TURN=0.4  # gender turn 场景下的最短字幕时长
ALIGN_LONG_CHUNK_BATCH_SIZE=1       # 长 chunk forced alignment 批大小（长 chunk 下保持 1 避免 OOM）

# --- 质量报告 ---
# Web 勾选质量报告时默认写入 video/<视频名>/；如需覆盖目录再填写此项。
QUALITY_REPORT_DIR=
QC_MAX_ASR_GENERATION_ERRORS=0      # ASR 生成异常数超过该值时报告 warning
QC_MAX_ASR_GENERATION_OVERFLOWS=0   # Whisper decoder overflow 超过该值时报告 warning
QC_MAX_ALIGN_FALLBACK=0.20          # forced alignment fallback 比例超过该值时报告 warning

# --- 翻译服务 ---
# 翻译服务 API Key。必须填写真实值。
API_KEY=your_key_here

# OpenAI-compatible API 地址，例如 DeepSeek 或其他兼容服务。
OPENAI_COMPATIBILITY_BASE_URL=https://api.deepseek.com

# 翻译模型名。
LLM_MODEL_NAME=deepseek-v4-pro

# 翻译 API 格式。chat 使用 /chat/completions；responses 使用 /responses。
# 默认 chat，只有 OpenAI Responses API 或兼容服务需要改为 responses。
LLM_API_FORMAT=chat

# 支持 reasoning effort 的模型可设置；不支持的服务可保持默认。
# 可选值由 Web 后端限制为 medium / xhigh。
LLM_REASONING_EFFORT=xhigh

# 目标语言。
TARGET_LANG=简体中文

# --- 模型下载 / 网络 ---
# HuggingFace 镜像地址。留空表示使用官方 huggingface.co。
# 必须包含 http:// 或 https://，例如：https://hf-mirror.com
HF_ENDPOINT=
# HF_ENDPOINT=https://hf-mirror.com

# --- 翻译偏好 ---
# 术语表格式：原文-译文, 原文-译文
# TRANSLATION_GLOSSARY=ちんぽ-肉棒, チンポ-肉棒
